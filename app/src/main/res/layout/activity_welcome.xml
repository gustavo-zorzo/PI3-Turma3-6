<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E2F5A"
    tools:context=".WelcomeActivity">

    <!-- Círculos decorativos de fundo -->

    <ImageView
        android:id="@+id/circleBottomRight"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:alpha="0.6"
        android:src="@drawable/bluecircle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="30dp"
        android:translationY="-200dp"/>

    <ImageView
        android:id="@+id/circleTopLeft"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:alpha="0.6"
        android:rotation="-263"
        android:src="@drawable/bluecircle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-25dp"
        android:translationY="65dp"/>

    <ImageView
        android:id="@+id/circleMiddle"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:alpha="0.7"
        android:src="@drawable/darkbluecircle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-50dp"
        android:translationY="100dp"/>

    <ImageView
        android:id="@+id/circleTopRight"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:alpha="0.6"
        android:src="@drawable/shieldcircle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="5dp"
        android:translationY="0dp"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/circleTopRight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Título principal -->
            <TextView
                android:id="@+id/titleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/welcome"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textAlignment="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="32dp" />

            <!-- Texto descritivo principal -->
            <TextView
                android:id="@+id/descriptionText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/info"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:lineSpacingExtra="6dp"
                app:layout_constraintTop_toBottomOf="@id/titleText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp" />

            <!-- Botão de Cadastro -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register"
                android:backgroundTint="#1A3B66"
                android:textColor="#FFFFFF"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="36dp"
                app:layout_constraintTop_toBottomOf="@id/descriptionText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="8dp" />

            <!-- Texto "Já tem uma conta? Faça login" -->
            <TextView
                android:id="@+id/txtLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/have_account"
                android:textColor="#A9D0F5"
                android:textSize="14sp"
                android:textAlignment="center"
                app:layout_constraintTop_toBottomOf="@id/btnRegister"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp" />

            <!-- Novo Texto "Ler termos de serviço" corrigido -->
            <TextView
                android:id="@+id/txtReadTerms"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="48dp"
                android:gravity="center"
                android:text="@string/ler_termos"
                android:textColor="#A9D0F5"
                android:textSize="14sp"
                android:textAlignment="center"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toBottomOf="@id/txtLogin"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
